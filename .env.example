# KnowHub Ethiopia Environment Variables

# ===== Supabase Configuration =====
# Get these from your Supabase project settings (https://supabase.com)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===== Gemini AI Tutor (Vercel Serverless) =====
# Get this from Google Cloud Console (https://console.cloud.google.com)
# This is REQUIRED for the AI Study Assistant to work
# Without it, the app will fall back to a limited offline mode
GEMINI_API_KEY=your-gemini-api-key-here

# ===== Optional: Development Mode =====
# Set to true to enable additional console logging
VITE_DEBUG_MODE=false
